{
  "manifest_version": 3,
  "name": "One-Click YouTube Downloader",
  "version": "3.0",
  "description": "Native YouTube downloader using yt-dlp via Native Messaging. Zero CORS, Zero Wait.",
  "permissions": [
    "nativeMessaging",
    "activeTab"
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}
