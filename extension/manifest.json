{
  "manifest_version": 3,
  "name": "FlashYT",
  "version": "2.2.6",
  "key": "",
  "description": "Fast and reliable YouTube video downloader extension.",
  "permissions": [
    "downloads",
    "storage",
    "tabs",
    "scripting",
    "nativeMessaging",
    "contextMenus",
    "notifications",
    "alarms",
    "cookies"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://*.googlevideo.com/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content_script.js"
      ],
      "css": [
        "content_styles.css"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "FlashYT",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}