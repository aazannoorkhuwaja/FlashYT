# FlashYT Environment Variables Template
# Copy this file to .env and fill in the values.
# DO NOT commit the .env file to Git.

# Google/YouTube InnerTube API Key (Required for fast quality prefetching)
# You can find this in any YouTube player request or your Google Cloud Console.
FLASHYT_INNERTUBE_KEY=your_api_key_here

# SSL Verification (Set to 1 to skip verification/ignore errors)
FLASHYT_SKIP_SSL_VERIFY=0

# Max concurrent download workers
FLASHYT_MAX_CONCURRENT=3
