<?xml version="1.0" encoding="utf-8"?>
<!--
    Single quality option row — used inside the quality container LinearLayout.
    Design: full-width button with label on left, size estimate on right.
    Rows separated by a subtle 1dp divider at the bottom (using background gradient).
    First row gets a red tint background when highlighted by ShareActivity.
-->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:layout_marginBottom="1dp"
    app:cardCornerRadius="0dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@android:color/transparent"
    app:strokeWidth="0dp"
    android:clickable="true"
    android:focusable="true"
    android:checkable="true"
    style="?attr/materialCardViewStyle">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- Lightning bolt icon — only visible on 1080p (primary) row -->
        <TextView
            android:id="@+id/ivQualityIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:text="⚡"
            android:textColor="@color/flashyt_red"
            android:textSize="14sp"
            android:visibility="gone" />

        <!-- Quality label, e.g. "1080p HD", "720p", "Audio" -->
        <TextView
            android:id="@+id/tvQualityLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="-0.01"
            android:text="Quality" />

        <!-- Size estimate, e.g. "180 MB" -->
        <TextView
            android:id="@+id/tvQualitySize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:text="— MB" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
