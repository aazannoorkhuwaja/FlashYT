<?xml version="1.0" encoding="utf-8"?>
<!--
    Single quality option row — used inside the quality container LinearLayout.
    Design: full-width button with label on left, size estimate on right.
    Rows separated by a subtle 1dp divider at the bottom (using background gradient).
    First row gets a red tint background when highlighted by ShareActivity.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <!-- Row content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- Lightning bolt icon — only visible on 1080p (primary) row -->
        <TextView
            android:id="@+id/ivQualityIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="⚡"
            android:textSize="14sp"
            android:visibility="gone" />

        <!-- Quality label, e.g. "1080p HD", "720p", "Audio MP3" -->
        <TextView
            android:id="@+id/tvQualityLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="normal"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="-0.01"
            android:text="Quality" />

        <!-- Size estimate, e.g. "180 MB" -->
        <TextView
            android:id="@+id/tvQualitySize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:text="— MB" />

    </LinearLayout>

    <!-- Subtle bottom divider (no hard lines — uses near-invisible divider color) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

</LinearLayout>
