<?xml version="1.0" encoding="utf-8"?>
<!--
    Quality picker bottom sheet.
    Matches the mockup: small 16:9 thumbnail on the left, title/channel on right,
    "Select format" header, then quality rows with label + size, separated by dividers.
    No card borders — surfaces are defined by background color contrast only (Kinetic Vault rule).
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_sheet"
    android:fillViewport="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Drag handle ──────────────────────────────── -->
        <View
            android:layout_width="36dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="20dp"
            android:background="#1AFFFFFF"
            android:backgroundTintMode="src_atop" />

        <!-- ── Video metadata row (thumbnail + title) ──── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            android:paddingBottom="20dp"
            android:gravity="center_vertical">

            <!-- Thumbnail — small, 16:9 aspect, rounded corners -->
            <androidx.cardview.widget.CardView
                android:layout_width="112dp"
                android:layout_height="63dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface_container_high">

                <ImageView
                    android:id="@+id/imgThumbnail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="@null" />

            </androidx.cardview.widget.CardView>

            <!-- Title + channel -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:lineSpacingMultiplier="1.1"
                    android:letterSpacing="-0.02"
                    android:text="Video Title" />

                <TextView
                    android:id="@+id/tvChannel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:text="Channel Name" />

            </LinearLayout>
        </LinearLayout>

        <!-- ── "Select format" header — matches mockup border+label style -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="20dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bg_sheet"
            app:strokeWidth="1dp"
            app:strokeColor="@color/flashyt_red">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/select_format"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▾"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Indented quality list (border-l from mockup = left margin line) -->
        <LinearLayout
            android:id="@+id/qualityContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="24dp"
            android:paddingEnd="0dp" />

        <!-- ── Footer tagline ──────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="16dp"
            android:text="@string/direct_download_tagline"
            android:textColor="@color/text_tertiary"
            android:textSize="10sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:gravity="center" />

        <!-- Bottom nav bar spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="24dp" />

    </LinearLayout>

</ScrollView>
