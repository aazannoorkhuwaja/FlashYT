<?xml version="1.0" encoding="utf-8"?>
<!--
    Loading state bottom sheet shown while yt-dlp fetches video metadata.
    Minimal: just the drag handle and a spinner with "Loading video info…" text.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_sheet"
    android:paddingBottom="48dp">

    <!-- Drag handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="32dp"
        android:background="#1AFFFFFF" />

    <!-- Spinner -->
    <ProgressBar
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="center_horizontal"
        android:indeterminate="true"
        android:indeterminateTint="@color/flashyt_red" />

    <!-- Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:text="@string/loading_video"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

</LinearLayout>
