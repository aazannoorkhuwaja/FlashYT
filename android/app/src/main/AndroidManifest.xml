<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network access for yt-dlp to stream/download -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Background download service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- Notifications for download progress (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Legacy storage for Android 9 and below (API ≤ 28) -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <application
        android:allowBackup="false"
        android:icon="@drawable/ic_flashyt"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.FlashYT">

        <!--
            ShareActivity — the heart of FlashYT.
            No LAUNCHER category = app won't appear in the home screen app drawer.
            It ONLY shows up in the Android share sheet for text/plain intents.
        -->
        <activity
            android:name=".ShareActivity"
            android:exported="true"
            android:theme="@style/Theme.FlashYT.Transparent"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <!-- Background download service — foregroundServiceType required on Android 10+ -->
        <service
            android:name=".DownloadService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- FileProvider for sharing downloaded files via content:// URIs (Android 7+) -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

    </application>

</manifest>
